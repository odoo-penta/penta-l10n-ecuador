    <!-- VALOR DECIMO -->
    <record id="rule_value_dcuar" model="hr.salary.rule">
      <field name="name">Valor Décimo Cuarto</field>
      <field name="code">VALDCUAR</field>
      <field name="sequence">5</field>
      <field name="struct_id" ref="l10n_ec_rrhh_penta.structure_employee_ec_decimo_cuarto"/>
      <field name="category_id" ref="l10n_ec_rrhh_penta.cat_fourteenth_value"/>
      <field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute"><![CDATA[
result = (payslip.get_basicec_amount()*payslip.worked_days_ec)/360
    ]]></field>
    </record>

    <!-- AJUSTE DECIMO -->
    <record id="rule_adjust_dcuar" model="hr.salary.rule">
      <field name="name">Ajuste Décimo Cuarto</field>
      <field name="code">ADJDCUAR</field>
      <field name="sequence">6</field>
      <field name="struct_id" ref="l10n_ec_rrhh_penta.structure_employee_ec_decimo_cuarto"/>
      <field name="category_id" ref="l10n_ec_rrhh_penta.cat_fourteenth_adjust"/>
      <field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute"><![CDATA[
if payslip.get_basicec_amount() != categories['FOURTEENTH_VALUE']:
  result = (payslip.get_basicec_amount() - categories['FOURTEENTH_VALUE'])
else:
  result = 0.0
    ]]></field>
    </record>

