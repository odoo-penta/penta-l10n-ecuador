    <!-- DECIMO TERCERO -->
    <!-- ========================= -->

    <!-- BASE IMPONIBLES IESS DECIMO TERCERO -->
    <record id="rule_base_dter" model="hr.salary.rule">
      <field name="name">Base Imponible IESS Décimo Tercero</field>
      <field name="code">GROSSDTER</field>
      <field name="sequence">1</field>
      <field name="struct_id" ref="l10n_ec_rrhh_penta.structure_employee_ec_decimo_tercero"/>
      <field name="category_id" ref="l10n_ec_rrhh_penta.cat_thirteenth_base"/>
      <field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute"><![CDATA[
amount = payslip.get_gross_value_thirteenth()
if inputs.get('PL_BASE_IMPONIBLE_DECIMO_TERCERO_ANTERIORES'):
  result = inputs['PL_BASE_IMPONIBLE_DECIMO_TERCERO_ANTERIORES'].amount + amount
else:
  result = amount
    ]]></field>
    </record>

