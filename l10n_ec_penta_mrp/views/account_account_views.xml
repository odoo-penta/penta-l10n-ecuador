<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Vista heredada de account.account -->
    <record id="view_account_form_inherit_penta_mrp" model="ir.ui.view">
        <field name="name">account.account.form.inherit.penta.mrp</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='allowed_journal_ids']" position="after">
            <field name="type_production_cost"/>
          </xpath>
        </field>
    </record>

  </data>
</odoo>
