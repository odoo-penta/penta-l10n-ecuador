<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Vista heredada de mrp.bom -->
    <record id="mrp_bom_form_view_inherit_penta_mrp" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.penta.mrp</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="replace">
            <field name="product_id" domain="[('type', '=', 'consu')]" context="{'default_is_storable': True}"/>
          </xpath>
        </field>
    </record>

  </data>
</odoo>
