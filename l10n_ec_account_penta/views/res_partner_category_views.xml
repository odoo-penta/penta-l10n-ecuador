<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_category_list_inherit_contact_type" model="ir.ui.view">
        <field name="name">res.partner.category.list.inherit.contact.type</field>
        <field name="model">res.partner.category</field>
        <field name="inherit_id" ref="base.view_partner_category_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='color']" position="before">
                <field name="contact_type"/>
            </xpath>
        </field>
    </record>
</odoo>
